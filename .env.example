# Variables (safe to commit)
# Non-sensitive configuration.

# Listing DB
LISTING_POSTGRES_USER=listing_user
LISTING_POSTGRES_DB=listing_db

# User DB
USER_POSTGRES_USER=user_user
USER_POSTGRES_DB=user_db

# Auth DB
AUTH_POSTGRES_USER=auth_user
AUTH_POSTGRES_DB=auth_db

# Chat DB
CHAT_POSTGRES_USER=chat_user
CHAT_POSTGRES_DB=chat_db

# Auction DB
AUCTION_POSTGRES_USER=auction_user
AUCTION_POSTGRES_DB=auction_db

# Seller DB
SELLER_POSTGRES_USER=seller_user
SELLER_POSTGRES_DB=seller_db

# gRPC Ports
AUTH_GRPC_PORT=50050
AUCTION_GRPC_PORT=50051
CHAT_GRPC_PORT=50052
GEO_GRPC_PORT=50053
LISTING_GRPC_PORT=50054
MARKETPRICE_GRPC_PORT=50055
SEARCH_GRPC_PORT=50056
SELLER_GRPC_PORT=50057
USER_GRPC_PORT=50058

# WebSocket Ports
CHAT_WS_PORT=8080
AUCTION_WS_PORT=8081

# gRPC Addresses
AUTH_GRPC_ADDR=auth:50050
AUCTION_GRPC_ADDR=auction:50051
CHAT_GRPC_ADDR=chat:50052
GEO_GRPC_ADDR=geo:50053
LISTING_GRPC_ADDR=listing:50054
MARKETPRICE_GRPC_ADDR=marketprice:50055
SEARCH_GRPC_ADDR=search:50056
SELLER_GRPC_ADDR=seller:50057
USER_GRPC_ADDR=user:50058

# WebSocket Addresses
CHAT_WS_ADDR=ws://chat:8080
AUCTION_WS_ADDR=ws://auction:8081

# Host-exposed ports (per container)
GATEWAY_HOST_PORT=8080
SEARCH_HOST_PORT=50056
CHAT_GRPC_HOST_PORT=50052
CHAT_WS_HOST_PORT=8082
GEO_GRPC_HOST_PORT=50053
LISTING_HOST_PORT=50054
MARKETPRICE_HOST_PORT=50055
AUCTION_GRPC_HOST_PORT=50051
AUCTION_WS_HOST_PORT=8081
USER_HOST_PORT=50058
SELLER_HOST_PORT=50057
AUTH_DB_HOST_PORT=5438
USER_DB_HOST_PORT=5433
SELLER_DB_HOST_PORT=5437
CHAT_DB_HOST_PORT=5434
AUCTION_DB_HOST_PORT=5436
LISTING_DB_HOST_PORT=5432

# Auth
POD_ID=chat-local

# GCP Pub/Sub
GCP_PROJECT_ID=your-gcp-project-id
GKE_CLUSTER_NAME=your-gke-cluster-name
GKE_CLUSTER_ZONE=your-gke-cluster-zone
ARTIFACT_REGISTRY_HOST=europe-central2-docker.pkg.dev
GCP_PUBSUB_TOPIC=chat-events
GCP_PUBSUB_SUBSCRIPTION=chat-sub-chat-local
GCP_PUBSUB_AUTOCREATE=false
AUCTION_PUBSUB_TOPIC=auction-events
AUCTION_PUBSUB_SUBSCRIPTION=auction-sub-auction-local

# Redis
REDIS_HOST=redis-cache
REDIS_PORT=6379

# Firebase / Firestore
FIREBASE_PROJECT_ID=your-firebase-project-id
FIRESTORE_DATABASE_ID=(default)
FIRESTORE_MESSAGES_COLLECTION=messages

# PostgreSQL
POSTGRES_DSN=

# Chat settings
CHAT_HISTORY_LIMIT=50

# Geo Market Insights Service
GEO_POSTGRES_SCHEMA=public
GEO_POSTGRES_TABLE=automotive_data
GEO_DEFAULT_LIMIT=20
GEO_MAX_LIMIT=100

# Secrets (keep local, do NOT commit)
# Sensitive values.

LISTING_DATABASE_URL=postgres://listing_user:listing_password@listing-db:5432/listing_db?sslmode=disable
LISTING_PYTHON_DATABASE_URL=postgresql://listing_user:listing_password@localhost:5432/listing_db?sslmode=disable
LISTING_POSTGRES_PASSWORD=listing_password

USER_DATABASE_URL=postgres://user_user:user_password@user-db:5432/user_db?sslmode=disable
USER_PYTHON_DATABASE_URL=postgresql://user_user:user_password@localhost:5433/user_db?sslmode=disable
USER_POSTGRES_PASSWORD=user_password

AUTH_DATABASE_URL=postgres://auth_user:auth_password@auth-db:5432/auth_db?sslmode=disable
AUTH_PYTHON_DATABASE_URL=postgresql://auth_user:auth_password@localhost:5438/auth_db?sslmode=disable
AUTH_POSTGRES_PASSWORD=auth_password

CHAT_DATABASE_URL=postgres://chat_user:chat_password@chat-db:5432/chat_db?sslmode=disable
CHAT_PYTHON_DATABASE_URL=postgresql://chat_user:chat_password@localhost:5434/chat_db?sslmode=disable
CHAT_POSTGRES_PASSWORD=chat_password

AUCTION_DATABASE_URL=postgres://auction_user:auction_password@auction-db:5432/auction_db?sslmode=disable
AUCTION_PYTHON_DATABASE_URL=postgresql://auction_user:auction_password@localhost:5436/auction_db?sslmode=disable
AUCTION_POSTGRES_PASSWORD=auction_password

SELLER_DATABASE_URL=postgres://seller_user:seller_password@seller-db:5432/seller_db?sslmode=disable
SELLER_PYTHON_DATABASE_URL=postgresql://seller_user:seller_password@localhost:5437/seller_db?sslmode=disable
SELLER_POSTGRES_PASSWORD=seller_password

JWT_PRIVATE_KEY_B64=base64_private_key_here
JWT_PUBLIC_KEY_B64=base64_public_key_here

FIREBASE_API_KEY=your-firebase-api-key

GCP_SA_KEY={"type":"service_account"}
