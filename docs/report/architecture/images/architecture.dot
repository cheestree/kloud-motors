digraph architecture {
  graph [
    rankdir=LR,
    bgcolor="white",
    pad="0.35",
    nodesep="0.6",
    ranksep="1.05",
    splines=ortho,
    compound=true,
    outputorder=edgesfirst,
    fontname="Helvetica",
    fontsize=20,
    labelloc=t
  ];

  node [
    shape=box,
    style="rounded,filled",
    color="#333333",
    fillcolor="white",
    fontname="Helvetica",
    fontsize=13,
    margin="0.12,0.08"
  ];

  edge [
    color="#555555",
    fontname="Helvetica",
    fontsize=11,
    arrowsize=0.8,
    penwidth=1.2
  ];

  subgraph cluster_client {
    label="Client applications";
    color="#a5d6a7";
    style="rounded,filled";
    fillcolor="#f1f8e9";
    fontsize=18;

    client_content [label="Browser / API consumers", fillcolor="#e8f5e9", penwidth=2];
  }

  subgraph cluster_ingress {
    label="NGINX Ingress";
    color="#a5d6a7";
    style="rounded,filled";
    fillcolor="#f1f8e9";
    fontsize=18;

    ingress_content [label="kloud-motors.com\n/api + WebSocket routes", fillcolor="#e8f5e9", penwidth=2];
  }

  subgraph cluster_gateway {
    label="Gateway service";
    color="#90caf9";
    style="rounded,filled";
    fillcolor="#f3f9fe";
    fontsize=18;

    gateway_content [label="REST API\nWebSocket proxy\nFirebase token validation\nPrometheus metrics", fillcolor="#e3f2fd", penwidth=2];
  }

  subgraph cluster_services {
    label="Go microservices";
    color="#dddddd";
    style="rounded,filled";
    fillcolor="#fbfbfb";
    fontsize=18;

    services [shape=plain, label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="7" COLOR="#777777" BGCOLOR="#ffffff">
        <TR><TD PORT="listing" BGCOLOR="#f5f5f5"><B>Listing</B><BR/><FONT POINT-SIZE="10">listing_db + Redis cache</FONT></TD></TR>
        <TR><TD PORT="search" BGCOLOR="#f5f5f5"><B>Search</B><BR/><FONT POINT-SIZE="10">listing_db + Redis cache</FONT></TD></TR>
        <TR><TD PORT="marketprice" BGCOLOR="#f5f5f5"><B>Market price</B><BR/><FONT POINT-SIZE="10">listing_db</FONT></TD></TR>
        <TR><TD PORT="geo" BGCOLOR="#f5f5f5"><B>Geo insights</B><BR/><FONT POINT-SIZE="10">listing_db</FONT></TD></TR>
        <TR><TD PORT="user" BGCOLOR="#ffffff"><B>User</B><BR/><FONT POINT-SIZE="10">user_db + Firebase login APIs</FONT></TD></TR>
        <TR><TD PORT="seller" BGCOLOR="#ffffff"><B>Seller</B><BR/><FONT POINT-SIZE="10">seller_db + listing_db</FONT></TD></TR>
        <TR><TD PORT="chat" BGCOLOR="#fff5f5"><B>Chat</B><BR/><FONT POINT-SIZE="10">gRPC + WS from gateway</FONT><BR/><FONT POINT-SIZE="10">uses Listing/Seller</FONT><BR/><FONT POINT-SIZE="10">chat_db + Firestore + Pub/Sub</FONT></TD></TR>
        <TR><TD PORT="auction" BGCOLOR="#fff5f5"><B>Auction</B><BR/><FONT POINT-SIZE="10">gRPC + WS from gateway</FONT><BR/><FONT POINT-SIZE="10">uses Listing</FONT><BR/><FONT POINT-SIZE="10">auction_db + Pub/Sub</FONT></TD></TR>
      </TABLE>
    >];
  }

  subgraph cluster_data {
    label="Data and cloud services";
    color="#f0d98a";
    style="rounded,filled";
    fillcolor="#fffdf0";
    fontsize=18;

    redis [shape=cylinder, label="Redis\ncache\nListing + Search only", fillcolor="#fff9c4"];

    cloudsql [shape=plain, label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#b79b37" BGCOLOR="#fffdf0">
        <TR><TD PORT="instance" COLSPAN="2" BGCOLOR="#fff8d6"><B>Cloud SQL PostgreSQL</B><BR/>cn-db-instance</TD></TR>
        <TR><TD PORT="listing"><B>listing_db</B></TD><TD ALIGN="LEFT">Listing, Search,<BR/>Market price, Geo insights,<BR/>Seller listing reads</TD></TR>
        <TR><TD PORT="user"><B>user_db</B></TD><TD ALIGN="LEFT">User</TD></TR>
        <TR><TD PORT="seller"><B>seller_db</B></TD><TD ALIGN="LEFT">Seller</TD></TR>
        <TR><TD PORT="chat"><B>chat_db</B></TD><TD ALIGN="LEFT">Chat</TD></TR>
        <TR><TD PORT="auction"><B>auction_db</B></TD><TD ALIGN="LEFT">Auction</TD></TR>
      </TABLE>
    >];

    firestore [shape=cylinder, label="Firestore\nchat messages\nChat only", fillcolor="#ede7f6"];
    firebase_content [label="Firebase Auth\nID tokens + login APIs", fillcolor="#ede7f6"];
    pubsub_content [label="Google Pub/Sub\nevents\nChat + Auction only", fillcolor="#ede7f6"];
  }

  subgraph cluster_platform {
    label="Platform and operations";
    color="#f4c27b";
    style="rounded,filled";
    fillcolor="#fff7ed";
    fontsize=18;

    platform_content [label="GitHub Actions + Terraform + GKE\nMonitoring + backups", fillcolor="#fff3e0", penwidth=2];
  }

  legend [shape=plain, label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#777777" BGCOLOR="#ffffff">
      <TR><TD COLSPAN="2"><B>Connection types</B></TD></TR>
      <TR><TD><B>Sample</B></TD><TD><B>Type</B></TD></TR>
      <TR><TD><FONT COLOR="#2e7d32">&#9472;&#9472;&#9472;&#9472;&#9472;&gt;</FONT></TD><TD>public HTTP / WebSocket</TD></TR>
      <TR><TD><FONT COLOR="#1565c0">&#9472;&#9472;&#9472;&#9472;&#9472;&gt;</FONT></TD><TD>gRPC service call</TD></TR>
      <TR><TD><FONT COLOR="#c62828">&#9472;&#9472;&#9472;&#9472;&#9472;&gt;</FONT></TD><TD>WebSocket / real-time path</TD></TR>
      <TR><TD><FONT COLOR="#555555">&#9472;&#9472;&#9472;&#9472;&#9472;&gt;</FONT></TD><TD>data, cache, or events</TD></TR>
      <TR><TD><FONT COLOR="#6a1b9a">- - - &gt;</FONT></TD><TD>authentication</TD></TR>
      <TR><TD><FONT COLOR="#ef6c00">- - - &gt;</FONT></TD><TD>platform operations</TD></TR>
    </TABLE>
  >];

  client_content -> ingress_content [color="#2e7d32", penwidth=1.8];
  ingress_content -> gateway_content [color="#2e7d32", penwidth=1.8];

  gateway_content -> services:grpc:w [color="#1565c0", penwidth=1.8];
  gateway_content -> services:ws:w [color="#c62828", penwidth=1.8];

  services:listing:e -> redis [color="#555555"];
  services:e -> cloudsql:w [color="#555555", penwidth=1.6];
  services:chat:e -> firestore [color="#555555"];
  services:chat:e -> pubsub_content [color="#555555", penwidth=1.5];

  gateway_content -> firebase_content [style=dashed, color="#6a1b9a", penwidth=1.5, constraint=false];
  services:user:e -> firebase_content [style=dashed, color="#6a1b9a", penwidth=1.5, constraint=false];

  platform_content -> ingress_content [style=dashed, color="#ef6c00", penwidth=1.5, constraint=false];
  platform_content -> gateway_content [style=dashed, color="#ef6c00", penwidth=1.5, constraint=false];
  platform_content -> cloudsql:instance:w [style=dashed, color="#ef6c00", penwidth=1.5, constraint=false];
}
