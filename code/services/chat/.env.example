# =========================
# Chat Service Environment
# =========================

# Pod identity
POD_ID=chat-local

# GCP Pub/Sub
GCP_PROJECT_ID=your-gcp-project-id
GCP_PUBSUB_TOPIC=chat-events
GCP_PUBSUB_SUBSCRIPTION=chat-sub-chat-local
GCP_PUBSUB_AUTOCREATE=false

# Firebase / Firestore
# Optional override. If empty, GCP_PROJECT_ID is used.
FIREBASE_PROJECT_ID=
FIRESTORE_MESSAGES_COLLECTION=messages

# PostgreSQL
# Example:
# postgresql://postgres:postgres@localhost:5432/chatdb?sslmode=disable
POSTGRES_DSN=

# Chat settings
CHAT_HISTORY_LIMIT=50

