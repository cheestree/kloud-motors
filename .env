# Listing DB
LISTING_DATABASE_URL=postgres://listing_user:listing_password@listing-db:5432/listing_db?sslmode=disable
LISTING_PYTHON_DATABASE_URL=postgresql://listing_user:listing_password@localhost:5432/listing_db
LISTING_POSTGRES_USER=listing_user
LISTING_POSTGRES_PASSWORD=listing_password
LISTING_POSTGRES_DB=listing_db

# User DB
USER_DATABASE_URL=postgres://user_user:user_password@user-db:5432/user_db
USER_PYTHON_DATABASE_URL=postgresql://user_user:user_password@localhost:5433/user_db
USER_POSTGRES_USER=user_user
USER_POSTGRES_PASSWORD=user_password
USER_POSTGRES_DB=user_db

# Auth DB
AUTH_DATABASE_URL=postgres://auth_user:auth_password@auth-db:5432/auth_db?sslmode=disable
AUTH_PYTHON_DATABASE_URL=postgresql://auth_user:auth_password@localhost:5433/auth_db
AUTH_POSTGRES_USER=auth_user
AUTH_POSTGRES_PASSWORD=auth_password
AUTH_POSTGRES_DB=auth_db

# Chat DB
CHAT_DATABASE_URL=postgres://chat_user:chat_password@chat-db:5432/chat_db?sslmode=disable
CHAT_PYTHON_DATABASE_URL=postgresql://chat_user:chat_password@localhost:5434/chat_db
CHAT_POSTGRES_USER=chat_user
CHAT_POSTGRES_PASSWORD=chat_password
CHAT_POSTGRES_DB=chat_db

# Geo DB
GEO_DATABASE_URL=postgres://geo_user:geo_password@geo-db:5432/geo_db?sslmode=disable
GEO_PYTHON_DATABASE_URL=postgresql://geo_user:geo_password@localhost:5435/geo_db
GEO_POSTGRES_USER=geo_user
GEO_POSTGRES_PASSWORD=geo_password
GEO_POSTGRES_DB=geo_db

# Auction DB
AUCTION_DATABASE_URL=postgres://auction_user:auction_password@auction-db:5432/auction_db?sslmode=disable
AUCTION_PYTHON_DATABASE_URL=postgresql://auction_user:auction_password@localhost:5436/auction_db
AUCTION_POSTGRES_USER=auction_user
AUCTION_POSTGRES_PASSWORD=auction_password
AUCTION_POSTGRES_DB=auction_db

# gRPC Addresses
LISTING_GRPC_ADDR=listing:50052
SEARCH_GRPC_ADDR=search:50051
AUTH_GRPC_ADDR=auth:50053
CHAT_GRPC_ADDR=chat:50054
GEO_GRPC_ADDR=geo:50055
AUCTION_GRPC_ADDR=auction:50056

# Auth
AUTH_JWT_SECRET=jwt-secret

# Pod identity
POD_ID=chat-local

# GCP Pub/Sub
GCP_PROJECT_ID=cn-project-491618
GCP_PUBSUB_TOPIC=chat-events
GCP_PUBSUB_SUBSCRIPTION=chat-sub-chat-local
GCP_PUBSUB_AUTOCREATE=true

# Firebase / Firestore
# Optional override. If empty, GCP_PROJECT_ID is used.
FIREBASE_PROJECT_ID=chat-db
FIRESTORE_MESSAGES_COLLECTION=messages

# PostgreSQL
# Example:
# postgresql://postgres:postgres@localhost:5432/chatdb?sslmode=disable
POSTGRES_DSN=

# Chat settings
CHAT_HISTORY_LIMIT=50

# Geo Market Insights Service
GEO_GRPC_PORT=50052
# Example: postgres://postgres:postgres@localhost:5432/market?sslmode=disable
GEO_POSTGRES_DSN=
GEO_POSTGRES_SCHEMA=public
GEO_POSTGRES_TABLE=automotive_data
GEO_DEFAULT_LIMIT=20
GEO_MAX_LIMIT=100

# Seller DB
SELLER_DATABASE_URL=postgres://seller_user:seller_password@seller-db:5432/seller_db
SELLER_PYTHON_DATABASE_URL=postgresql://seller_user:seller_password@localhost:5437/seller_db
SELLER_POSTGRES_USER=seller_user
SELLER_POSTGRES_PASSWORD=seller_password
SELLER_POSTGRES_DB=seller_db